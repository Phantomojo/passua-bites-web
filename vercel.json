{
  "framework": null,
  "buildCommand": "pnpm run build",
  "outputDirectory": "dist/public",
  "installCommand": "pnpm install",
  "devCommand": "pnpm run dev",
  "builds": [
    {
      "src": "api/index.ts",
      "use": "@vercel/node",
      "config": {
        "esbuild": {
          "alias": {
            "@shared": "./shared"
          }
        }
      }
    }
  ],
  "routes": [{ "src": "/api/(.*)", "dest": "api/index.ts" }]
}
